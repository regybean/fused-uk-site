---
import "@/styles/global.css"
import Header from "@/components/site/Header.astro"
import Footer from "@/components/site/Footer.astro"

interface Props {
  title?: string
  description?: string
}

const {
  title = "FUSED UK PAT Testing",
  description = "Specialist, UK wide portable appliance testing (PAT testing) services for businesses, landlords and public organisations.",
} = Astro.props
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <script is:inline>
      const t = localStorage.getItem("theme")
      const dark = t === "dark" || (!t && window.matchMedia("(prefers-color-scheme: dark)").matches)
      document.documentElement.classList.toggle("dark", dark)
    </script>
  </head>
  <body class="min-h-svh bg-background text-foreground antialiased">
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
