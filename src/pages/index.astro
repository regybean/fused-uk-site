---
import Layout from "@/layouts/main.astro"
import { Button } from "@/components/ui/button"
import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card"
import { Badge } from "@/components/ui/badge"
import { BookNowButton } from "@/components/site/BookNowButton"
import { HeroCarousel } from "@/components/site/HeroCarousel"
import { ReviewsCarousel } from "@/components/site/ReviewsCarousel"
import TickList from "@/components/site/TickList.astro"
import Eyebrow from "@/components/site/Eyebrow.astro"
import CtaBand from "@/components/site/CtaBand.astro"

const benefits = [
  "Beat any quotation",
  "Same-day callout and flexible after-hours/weekend testing",
  "On-time UK-wide arrival",
  "DBS-checked and fully insured engineers",
  "Testing per IEE Code of Practice",
  "Itemised asset reports",
  "No hidden charges",
]

const services = [
  {
    title: "Fully Inclusive PAT Testing",
    body: "Inspection and safety testing of portable appliances with the latest computerised equipment. Testing follows IEE Code of Practice standards. Minor repairs and replacement fuses/IT leads are provided at no charge.",
    image: "/iet-code-of-practice.jpg",
  },
  {
    title: "Microwave Leakage Testing",
    body: "Radiation intensity assessments are conducted, with reports detailing mW/cm2 output levels.",
    image: "/microwave-leakage-test.jpg",
  },
  {
    title: "Emergency Light Testing",
    body: "The company provides inspection and testing for 6-monthly and annual compliance periods, typically running the full 3-hour rated duration. Services include verifying correct fixture placement and signage.",
    image: null,
  },
]

const whyPat = [
  {
    title: "Legal requirement",
    body: "The Electricity at Work Regulations requires that employers maintain their electrical systems at work to prevent any danger to anyone. This is a legal requirement.",
  },
  {
    title: "Insurance risk",
    body: "Insurers are fully entitled to reduce, delay or even refuse to pay on a claim for damage caused by a portable appliance that has not been PAT tested.",
  },
  {
    title: "Prosecution risk",
    body: "Failure to comply can result in prosecution, fine and or/imprisonment.",
  },
  {
    title: "Landlord duty",
    body: "The Electrical Equipment (Safety) Regulations 1994 requires that all mains electrical equipment (cookers, washing machines, kettles, etc), new or second-hand, supplied with the accommodation must be safe.",
  },
]
---

<Layout>
  {/* 1. Hero carousel */}
  <section class="relative isolate overflow-hidden bg-neutral-950">
    <div class="absolute inset-0 -z-10">
      <HeroCarousel client:load />
      <div class="absolute inset-0 bg-gradient-to-b from-black/70 via-black/55 to-black/75"></div>
    </div>

    <div class="mx-auto max-w-[1200px] px-4 py-20 text-center text-white md:px-6 md:py-32">
      <p class="text-primary text-xs font-semibold tracking-[0.25em] uppercase">
        UK-wide PAT testing specialists
      </p>
      <h1 class="mt-4 text-4xl font-semibold tracking-tight md:text-6xl">
        FUSED UK PAT Testing
      </h1>
      <p class="mx-auto mt-6 max-w-3xl text-base text-white/85 md:text-lg">
        Welcome to FUSED UK. We provide specialist, UK wide, portable appliance
        testing (PAT testing) services that enable you to comply with health
        and safety, insurance and site survey regulations.
      </p>

      <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
        <BookNowButton client:load size="lg" className="text-sm" />
        <Button
          asChild
          client:load
          size="lg"
          variant="outline"
          className="border-white/30 bg-transparent text-sm text-white hover:bg-white/10 hover:text-white"
        >
          <a href="/quote">Get a Quote</a>
        </Button>
      </div>

      <p class="mt-8 text-sm leading-relaxed text-white/75">
        We aim to 'beat any quote', so if you require electrical testing
        services, please don't hesitate to call us on
        <a
          href="tel:07729577307"
          class="text-primary font-semibold hover:underline"
        >
          07729 577307
        </a>.
      </p>
    </div>
  </section>

  {/* 2. Key benefits strip */}
  <section class="border-y bg-muted/30">
    <div class="mx-auto max-w-[1200px] px-4 py-10 md:px-6 md:py-14">
      <TickList
        items={benefits}
        class="grid gap-x-8 gap-y-3 sm:grid-cols-2 lg:grid-cols-3"
      />
    </div>
  </section>

  {/* 3. Services preview */}
  <section class="mx-auto max-w-[1200px] px-4 py-16 md:px-6 md:py-24">
    <Eyebrow>What we do</Eyebrow>
    <h2 class="mt-3 text-center text-3xl font-semibold tracking-tight md:text-4xl">
      Services
    </h2>

    <div class="mt-12 grid gap-6 md:grid-cols-3">
      {
        services.map((s) => (
          <Card className="overflow-hidden pt-0 pb-0">
            {s.image ? (
              <div class="aspect-[4/3] overflow-hidden bg-muted">
                <img
                  src={s.image}
                  alt={s.title}
                  loading="lazy"
                  class="h-full w-full object-cover transition-transform duration-500 hover:scale-105"
                />
              </div>
            ) : (
              <div class="aspect-[4/3] bg-gradient-to-br from-primary/10 via-primary/5 to-transparent">
                <div class="flex h-full items-center justify-center">
                  <svg
                    width="56"
                    height="56"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.4"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="text-primary/70"
                  >
                    <path d="M13 2L3 14h7l-1 8 10-12h-7l1-8z" />
                  </svg>
                </div>
              </div>
            )}
            <CardHeader className="pt-5">
              <CardTitle className="text-lg">{s.title}</CardTitle>
            </CardHeader>
            <CardContent className="pb-6">
              <p class="text-muted-foreground text-sm leading-relaxed">
                {s.body}
              </p>
            </CardContent>
          </Card>
        ))
      }
    </div>

    <div class="mt-10 text-center">
      <a
        href="/services"
        class="text-primary hover:text-primary/80 inline-flex items-center gap-1 text-sm font-semibold"
      >
        See all services
        <span aria-hidden="true">→</span>
      </a>
    </div>
  </section>

  <div class="mx-auto max-w-[1200px] px-4 md:px-6">
    <hr class="border-border" />
  </div>

  {/* 5. Why PAT Test? teaser */}
  <section class="mx-auto max-w-[1200px] px-4 py-16 md:px-6 md:py-24">
    <Eyebrow>Why it matters</Eyebrow>
    <h2 class="mt-3 text-center text-3xl font-semibold tracking-tight md:text-4xl">
      Why PAT Test?
    </h2>

    <div class="mt-12 grid gap-5 md:grid-cols-2 lg:grid-cols-4">
      {
        whyPat.map((w) => (
          <Card className="h-full border-t-4 border-t-primary">
            <CardHeader>
              <CardTitle className="text-base">{w.title}</CardTitle>
            </CardHeader>
            <CardContent>
              <p class="text-muted-foreground text-sm leading-relaxed">
                {w.body}
              </p>
            </CardContent>
          </Card>
        ))
      }
    </div>

    <div class="mt-10 text-center">
      <a
        href="/why-pat"
        class="text-primary hover:text-primary/80 inline-flex items-center gap-1 text-sm font-semibold"
      >
        Read the full guide
        <span aria-hidden="true">→</span>
      </a>
    </div>
  </section>

  {/* 6. Reviews carousel */}
  <section class="bg-muted/30 border-y">
    <div class="mx-auto max-w-[1200px] px-4 py-16 md:px-6 md:py-24">
      <Eyebrow>Reviews</Eyebrow>
      <h2 class="mt-3 text-center text-3xl font-semibold tracking-tight md:text-4xl">
        What our clients say
      </h2>
      <div class="mt-12">
        <ReviewsCarousel client:visible />
      </div>
    </div>
  </section>

  {/* 7. Trust strip */}
  <section class="border-b">
    <div class="mx-auto flex max-w-[1200px] flex-col items-center justify-center gap-6 px-4 py-10 sm:flex-row sm:gap-10 md:px-6">
      <img
        src="/disclosure-and-barring-service.png"
        alt="Disclosure and Barring Service"
        class="h-14 w-auto md:h-16"
      />
      <Badge
        variant="secondary"
        className="bg-primary/10 text-primary border-primary/20 px-4 py-2 text-sm font-semibold"
      >
        Fully insured up to £5 million
      </Badge>
    </div>
  </section>

  {/* 8. Final CTA band */}
  <CtaBand />
</Layout>
