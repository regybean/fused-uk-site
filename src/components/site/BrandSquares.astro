---
interface Props {
  size?: number
  class?: string
  orientation?: "vertical" | "horizontal"
}
const {
  size = 12,
  class: className,
  orientation = "vertical",
} = Astro.props
const dim = `${size}px`
---

<span
  class:list={[
    "inline-flex shrink-0",
    orientation === "vertical" ? "flex-col" : "flex-row",
    className,
  ]}
  aria-hidden="true"
>
  <span class="block bg-secondary" style={`width:${dim};height:${dim}`}></span>
  <span class="block bg-accent" style={`width:${dim};height:${dim}`}></span>
  <span class="block bg-primary" style={`width:${dim};height:${dim}`}></span>
</span>
