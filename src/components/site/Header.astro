---
import { BookNowButton } from "./BookNowButton"
import { ThemeToggle } from "./ThemeToggle"
import { MobileNav } from "./MobileNav"
import BrandSquares from "./BrandSquares.astro"

const links = [
  { href: "/", label: "Home" },
  { href: "/services", label: "Services" },
  { href: "/why-pat", label: "Why PAT Test" },
  { href: "/about", label: "About Us" },
  { href: "/quote", label: "Get a Quote" },
]

const path = Astro.url.pathname
---

<header class="sticky top-0 z-50 border-b border-white/10 bg-neutral-950 text-white">
  <div class="mx-auto flex h-16 max-w-[1200px] items-center gap-4 px-4 md:px-6">
    <a href="/" class="flex items-center gap-2" aria-label="FUSED UK home">
      <img
        src="/fused-uk-logo.jpg"
        alt="FUSED UK"
        class="h-9 w-auto md:h-10"
      />
    </a>
    <BrandSquares size={10} />

    <nav class="ml-6 hidden flex-1 items-center gap-1 md:flex">
      {
        links.map((l) => {
          const active =
            l.href === "/" ? path === "/" : path.startsWith(l.href)
          return (
            <a
              href={l.href}
              class:list={[
                "px-3 py-2 text-sm font-medium tracking-tight transition-colors",
                active ? "text-primary" : "text-white/80 hover:text-white",
              ]}
            >
              {l.label}
            </a>
          )
        })
      }
    </nav>

    <div class="ml-auto hidden items-center gap-3 md:flex">
      <a
        href="tel:07729577307"
        class="text-sm font-medium text-white/80 transition-colors hover:text-white"
      >
        07729 577307
      </a>
      <BookNowButton client:load size="lg" />
      <ThemeToggle client:load />
    </div>

    <div class="ml-auto flex items-center gap-1 md:hidden">
      <a
        href="tel:07729577307"
        aria-label="Call FUSED UK"
        class="inline-flex size-9 items-center justify-center text-white/80 hover:text-white"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><path
            d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92z"
          ></path></svg
        >
      </a>
      <MobileNav client:load />
    </div>
  </div>
</header>
