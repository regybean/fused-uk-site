---
import { BookNowButton } from "./BookNowButton"
import { Button } from "@/components/ui/button"
---

<section
  class="relative overflow-hidden bg-neutral-900 text-white"
  style="background-image: radial-gradient(ellipse 60% 80% at 50% 50%, rgba(255,255,255,0.04), transparent 70%), linear-gradient(to bottom, #1a1a1a 0%, #0f0f0f 100%);"
>
  <div
    class="pointer-events-none absolute inset-x-0 bottom-0 h-px"
    style="background: linear-gradient(to right, transparent, var(--color-primary, #f5b400) 50%, transparent);"
  >
  </div>
  <div class="relative mx-auto max-w-[1200px] px-4 py-16 text-center md:px-6 md:py-20">
    <p
      class="text-primary text-xs font-semibold tracking-[0.2em] uppercase"
    >
      Ready when you are
    </p>
    <a
      href="tel:07729577307"
      class="mt-4 inline-block text-3xl font-semibold tracking-tight hover:text-primary md:text-5xl"
    >
      07729 577307
    </a>
    <p class="mt-3 text-sm text-white/60">
      Same-day callouts · UK-wide · DBS-checked engineers
    </p>
    <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
      <BookNowButton client:load size="lg" className="text-sm" />
      <Button asChild client:load size="lg" variant="outline" className="border-white/30 bg-transparent text-sm text-white hover:bg-white/10 hover:text-white">
        <a href="/quote">Get a Quote</a>
      </Button>
    </div>
  </div>
</section>
